# Copy this file to .env and fill in the values.
# Never commit .env to git — it contains private keys.

# Governor private key — Ganache accounts[0] from the candy-maple mnemonic.
# Printed by Ganache on startup next to address 0xa3BCcC4483444fcf1A9C2781343a8cFaCDE2594D.
GOVERNOR_PRIVATE_KEY=0x_your_ganache_governor_private_key_here

# Sepolia RPC URL from Alchemy (https://www.alchemy.com)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key-here
